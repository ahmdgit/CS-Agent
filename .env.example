# GEMINI API KEYS - Multi-Key Fallback Support
# ================================================
# You can add up to 10+ API keys for automatic fallback when quota is exceeded.
#
# Option 1: Single Key (Backward Compatible)
# GEMINI_API_KEY="sk-proj-xxxxxxxxx"
#
# Option 2: Multiple Keys (Recommended for Production)
# Separate multiple keys with commas. System will automatically switch to the next key
# when quota is exceeded (429 / RESOURCE_EXHAUSTED errors).
# GEMINI_API_KEYS="key1,key2,key3,key4,key5,key6,key7,key8,key9,key10"
#
# Environment Variable Priority:
# 1. GEMINI_API_KEYS (comma-separated list) - Recommended
# 2. GEMINI_API_KEY (single key) - Fallback
# 3. Settings UI - User can paste keys in the app (stored in localStorage)
#
# EXAMPLE:
GEMINI_API_KEYS="YOUR_API_KEY_1,YOUR_API_KEY_2,YOUR_API_KEY_3"

# VITE Alternative (for Vite build process):
# VITE_GEMINI_API_KEYS="YOUR_API_KEY_1,YOUR_API_KEY_2,YOUR_API_KEY_3"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"



